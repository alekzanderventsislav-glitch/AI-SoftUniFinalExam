{
  "name": "zdravosloven-zhivot",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "predev": "node scripts/generate-supabase-env.mjs",
    "prebuild": "node scripts/generate-supabase-env.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "db:migrate": "node scripts/run-migration.mjs",
    "db:seed": "node scripts/run-seed.mjs",
    "db:fix-images": "node scripts/run-fix-images.mjs",
    "generate:foods": "node scripts/generate-foods-catalog.mjs",
    "generate:foods-seed": "node scripts/generate-foods-seed.mjs",
    "download:food-images": "node scripts/download-food-images.mjs",
    "download:food-images:force": "node scripts/download-food-images.mjs --force",
    "upload:food-images": "node --env-file=.env scripts/upload-food-images-to-supabase.mjs",
    "download:food-images:fixes": "node scripts/download-food-images.mjs --fixes",
    "upload:food-images:fixes": "node --env-file=.env scripts/upload-food-images-to-supabase.mjs --fixes",
    "sync:food-images:fixes": "npm run generate:foods && npm run download:food-images:fixes && npm run upload:food-images:fixes"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@supabase/supabase-js": "^2.49.1",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3"
  },
  "devDependencies": {
    "pg": "^8.13.1",
    "vite": "^6.0.7"
  }
}
