# Copy to .env and fill with your Supabase project credentials
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Browser-safe key: "anon" / "public" (NOT secret, NOT service_role)
# Legacy JWT: eyJhbGciOiJIUzI1NiIs...
# New keys:   sb_publishable_...
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Database password (Project Settings → Database) – used for npm run db:migrate / db:seed
SUPABASE_DB_PASSWORD=your-database-password

# Optional – author for seeded recipes (default: admin@zdravosloven.bg)
SEED_AUTHOR_EMAIL=admin@zdravosloven.bg
